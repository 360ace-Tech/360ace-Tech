############################################
# Public site config
############################################
NEXT_PUBLIC_SITE_URL=https://360ace.tech
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_MAINTENANCE=false
# Optional: ISO timestamp for countdown (e.g., 2025-12-31T23:59:59Z)
NEXT_PUBLIC_REOPEN_AT=

############################################
# Contact + Email (MailerSend)
############################################
MAILERSEND_API_KEY=
CONTACT_TO_EMAIL=hello@example.com
CONTACT_FROM_EMAIL=no-reply@example.com
CONTACT_SUBJECT_PREFIX="New contact from 360ace.tech:"

############################################
# Cloudflare Turnstile
# Public site key and secret for server verification
############################################
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

############################################
# Anti-spam timing (milliseconds)
############################################
CONTACT_MIN_SUBMIT_MS=2000
